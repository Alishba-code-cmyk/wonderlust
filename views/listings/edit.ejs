<% layout('layouts/boilerplate') -%>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2"> 
    <h1>edit your listing</h1>
    <form method="post" action="/listings/<%=listing.id%>?_method=put">
    <div class="mb-3">
    <label for="title"  class="from-label">title</label>
    <input name="listing[title]" class="form-control" value="<%=listing.title%>" type="text" >
    </div> 
    <div class="mb-3">
    <label class="from-label" for="description">description</label>
    <textarea name="listing[description]" class="form-control" ><%=listing.description%></textarea>
    </div>
    <div class="mb-3">
    <label class="from-label" for="image">image link</label>
    <input name="listing[image]" value="<%=listing.image%>" class="form-control"  type="text">
    </div>
 <div class="row">
            <div class="mb-3 col-md-4">
        <label class="form-label" for="price">price  </label>
        <input name="listing[price]" class="form-control" value="<%=listing.price%>" type="number">
       </div>
        <div class="mb-3 col-md-8">
            <label for="country"class="form-label">country</label>
        <input name="listing[country]" class="form-control" value="<%=listing.country%>" type="text">
        </div>
        </div>
         <div class="mb-3" >
            <label for="location"class="form-label">location</label>
        <input name="listing[location]" class="form-control" value="<%=listing.location%>" type="text">
        </div>
       

<button class="btn btn-dark edit-btn  mt-3">edit</button><br/><br/>
</form>
</body>
</div></div>



